# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=smart_office

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# CORS (HTTP + WebSocket): comma-separated, or set FRONTEND_URL alone
# CORS_ORIGINS=http://localhost:3001,http://192.168.1.9:3000
# FRONTEND_URL=http://localhost:3001

# Swagger at /api/docs — off in production unless ENABLE_SWAGGER=true
# ENABLE_SWAGGER=false

# Gemini (for AI Agent)
GEMINI_API_KEY=your-gemini-api-key
# Optional: override model name
GEMINI_MODEL=gemini-2.5-flash

# AI Vision Service
AI_VISION_URL=http://localhost:8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
